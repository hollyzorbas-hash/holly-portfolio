---
import { Image } from 'astro:assets';
import splash5de from '../assets/projects/splash-5de.png';
import splashRad from '../assets/projects/splash-rad.png';
import postfileRad from '../assets/projects/postfile-rad.png';
import postfileSave from '../assets/projects/postfile-save.png';

const phones = [
  { image: splash5de, alt: '5-Day Early splash page', delay: '0s' },
  { image: splashRad, alt: 'Refund Advance splash page', delay: '1.5s' },
  { image: postfileRad, alt: 'Refund Advance post-file page', delay: '3s' },
  { image: postfileSave, alt: 'Save post-file page', delay: '4.5s' },
];
---

<div class="scrolling-phones-container">
  <div class="phones-grid">
    {phones.map((phone) => (
      <div class="phone-wrapper" style={`--delay: ${phone.delay}`}>
        <div class="phone-viewport">
          <div class="scrolling-content">
            <Image
              src={phone.image}
              alt={phone.alt}
              width={130}
              densities={[1, 2]}
            />
          </div>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .scrolling-phones-container {
    background: #D4E8D2;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .phones-grid {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
  }

  .phone-wrapper {
    flex-shrink: 0;
  }

  .phone-viewport {
    width: 90px;
    height: 185px;
    overflow: hidden;
    position: relative;
  }

  .scrolling-content {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    animation: scrollPhone 8s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  .scrolling-content img {
    width: 90px;
    height: auto;
    display: block;
  }

  @keyframes scrollPhone {
    0%, 15% {
      top: 0;
    }
    40%, 60% {
      top: calc(-100% + 185px);
    }
    85%, 100% {
      top: 0;
    }
  }
</style>
