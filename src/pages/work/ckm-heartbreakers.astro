---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import finalImage from '../../assets/projects/ckm-modal-final.png';
import fromToImage from '../../assets/projects/ckm-from-to.png';
---

<BaseLayout
  title="Deposit Retention Modal — Holly Zorbas"
  description="A/B tested comparison modal to reduce churn to external banks."
>
  <article class="mini-case-study">
    <!-- Header -->
    <header class="mini-header">
      <a href="/#work" class="back-link">&larr; back to work</a>
      <p class="project-label">Credit Karma Money</p>
      <h1>Deposit Retention Modal</h1>
      <p class="project-tagline">Saving product take rates from mid-funnel mind-changers with a comparison modal.</p>
    </header>

    <!-- Two Column Layout -->
    <div class="mini-layout">
      <!-- Left: Sticky Image -->
      <div class="mini-image-column">
        <div class="mini-image-wrapper">
          <Image src={finalImage} alt="CKM comparison modal showing benefits vs traditional banks" width={400} densities={[1, 2]} />
        </div>
        <p class="image-caption">The redesigned modal with comparison chart</p>
      </div>

      <!-- Right: Content -->
      <div class="mini-content-column">
        <section class="mini-section">
          <h2>Context</h2>
          <p>I was the sole content designer on the TurboTax-to-Credit Karma Money (TT2CKM) track, focused on funneling TurboTax customers into Credit Karma's banking products. The value prop was simple: deposit your refund into a CKM checking account and get it a little earlier than depositing to your own bank.</p>
          <p>But we had a problem: customers would initially choose CKM as their deposit option, then switch to "deposit to another bank" at confirmation. We needed to <b>capture mid-funnel mind-changers who had already created accounts</b>.</p>
        </section>

        <section class="mini-section">
          <h2>The fix</h2>
          <p>The existing experience sent customers to an entirely separate screen after they changed their deposit choice—too much friction, too easy to keep clicking away.</p>
          <p>We changed this to an immediate modal popup that:</p>
          <ul>
            <li>Caught them right at the moment of the decision change</li>
            <li>Featured the concrete benefits of the CKM account</li>
            <li>Anchored language on their <em>first</em> choice, not the mind-change (they'd already created the account—the hard part was done)</li>
          </ul>
        </section>

        <section class="mini-section">
          <h2>My input</h2>
          <ul>
            <li>Added a comparison chart to highlight CKM benefits vs. traditional banks—especially the Credit Builder tool, which was a strong differentiator</li>
            <li>Worked with legal and marketing to soften disclosures where possible, reducing visual clutter</li>
            <li>Rewrote the primary CTA to anchor on CKM as the first choice ("Keep Credit Karma Money") rather than framing it as a reversal</li>
          </ul>
        </section>

        <section class="mini-section">
          <h2>Impact</h2>
          <p><strong>100.3 index to control</strong> with higher take rates than the original experience.</p>
          <p>Launched September 2023, moved to baseline February 2024.</p>
        </section>
      </div>
    </div>

    <!-- Full Width Image -->
    <div class="full-width-image">
      <Image src={fromToImage} alt="Before and after comparison of the CKM modal" width={1200} densities={[1, 2]} />
    </div>
  </article>
</BaseLayout>

<style>
  .mini-case-study {
    max-width: 100%;
  }

  /* Header */
  .mini-header {
    padding: var(--space-12) 0 var(--space-8);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-12);
  }

  .back-link {
    font-size: 0.875rem;
    color: var(--color-muted);
    display: inline-block;
    margin-bottom: var(--space-6);
  }

  .back-link:hover {
    color: var(--color-text);
    opacity: 1;
  }

  .project-label {
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    margin-bottom: var(--space-2);
  }

  .mini-header h1 {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    margin-bottom: var(--space-3);
    line-height: 1.2;
  }

  .project-tagline {
    font-size: 1rem;
    color: var(--color-muted);
    max-width: 500px;
    line-height: 1.6;
  }

  /* Two Column Layout */
  .mini-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  /* Left Column - Sticky Image */
  .mini-image-column {
    position: sticky;
    top: var(--space-8);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .mini-image-wrapper {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    max-width: 360px;
  }

  .mini-image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
  }

  .image-caption {
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin-top: var(--space-3);
    text-align: center;
  }

  /* Right Column - Content */
  .mini-content-column {
    padding-bottom: var(--space-16);
  }

  .mini-section {
    margin-bottom: var(--space-12);
  }

  .mini-section:last-child {
    margin-bottom: 0;
  }

  .mini-section h2 {
    font-size: 1.25rem;
    font-family: var(--font-heading);
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: var(--space-6);
  }

  .mini-section p {
    line-height: 1.7;
    margin-bottom: var(--space-4);
  }

  .mini-section p:last-child {
    margin-bottom: 0;
  }

  .mini-section ul {
    margin: var(--space-4) 0 var(--space-6);
    padding-left: var(--space-8);
    line-height: 1.7;
  }

  .mini-section ul li {
    margin-bottom: var(--space-3);
  }

  /* Full Width Image */
  .full-width-image {
    margin-top: var(--space-16);
  }

  .full-width-image img {
    width: 100%;
    border-radius: 8px;
    border: 1px solid var(--color-border);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .mini-layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .mini-image-column {
      position: relative;
      top: 0;
    }

    .comparison-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
