---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
// import projectImage from '../../assets/projects/dynamic-island.png';
---

<BaseLayout
  title="Dynamic Island — Holly Zorbas"
  description="iOS Dynamic Island notification content across six expert-progress states."
>
  <article class="mini-case-study">
    <!-- Header -->
    <header class="mini-header">
      <a href="/#work" class="back-link">&larr; back to work</a>
      <p class="project-label">TurboTax iOS</p>
      <h1>Dynamic Island</h1>
      <p class="project-tagline">iOS Dynamic Island notification content across six expert-progress states.</p>
    </header>

    <!-- Two Column Layout -->
    <div class="mini-layout">
      <!-- Left: Sticky Image -->
      <div class="mini-image-column">
        <div class="mini-image-wrapper">
          <!-- Uncomment when image is ready -->
          <!-- <Image src={projectImage} alt="Dynamic Island notification states" width={500} densities={[1, 2]} /> -->
          <div class="image-placeholder">Image coming soon</div>
        </div>
      </div>

      <!-- Right: Content -->
      <div class="mini-content-column">
        <section class="mini-section">
          <h2>Context</h2>
          <p>[Placeholder: What was the situation? What problem needed solving? What was the user experience like before?]</p>
        </section>

        <section class="mini-section">
          <h2>The fix</h2>
          <p>[Placeholder: What was the solution? How did you approach it? What content strategy did you use?]</p>
        </section>

        <section class="mini-section">
          <h2>My input</h2>
          <ul>
            <li>[Placeholder: Specific contribution 1]</li>
            <li>[Placeholder: Specific contribution 2]</li>
            <li>[Placeholder: Specific contribution 3]</li>
          </ul>
        </section>

        <section class="mini-section">
          <h2>Impact</h2>
          <p>[Placeholder: What were the results? Any metrics or outcomes?]</p>
        </section>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .mini-case-study {
    max-width: 100%;
  }

  /* Header */
  .mini-header {
    padding: var(--space-12) 0 var(--space-8);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-12);
  }

  .back-link {
    font-size: 0.875rem;
    color: var(--color-muted);
    display: inline-block;
    margin-bottom: var(--space-6);
  }

  .back-link:hover {
    color: var(--color-text);
    opacity: 1;
  }

  .project-label {
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    margin-bottom: var(--space-2);
  }

  .mini-header h1 {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    margin-bottom: var(--space-3);
    line-height: 1.2;
  }

  .project-tagline {
    font-size: 1rem;
    color: var(--color-muted);
    max-width: 500px;
    line-height: 1.6;
  }

  /* Two Column Layout */
  .mini-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  /* Left Column - Sticky Image */
  .mini-image-column {
    position: sticky;
    top: var(--space-8);
  }

  .mini-image-wrapper {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .mini-image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
  }

  .image-placeholder {
    aspect-ratio: 3 / 4;
    background: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    font-size: 0.875rem;
  }

  /* Right Column - Content */
  .mini-content-column {
    padding-bottom: var(--space-16);
  }

  .mini-section {
    margin-bottom: var(--space-10);
  }

  .mini-section:last-child {
    margin-bottom: 0;
  }

  .mini-section h2 {
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    margin-bottom: var(--space-3);
    font-weight: 500;
  }

  .mini-section p {
    line-height: 1.7;
    margin-bottom: var(--space-4);
  }

  .mini-section p:last-child {
    margin-bottom: 0;
  }

  .mini-section ul {
    margin-left: var(--space-5);
    line-height: 1.7;
  }

  .mini-section ul li {
    margin-bottom: var(--space-2);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .mini-layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .mini-image-column {
      position: relative;
      top: 0;
    }

    .image-placeholder {
      aspect-ratio: 16 / 10;
    }
  }
</style>
