---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import columnImage from '../../assets/projects/splash-rad-column.png';
import fullWidthImage from '../../assets/projects/splash-full-width.png';
---

<BaseLayout
  title="Cross-Product Landing Pages — Holly Zorbas"
  description="Cross-product landing page optimization — 2.6M churned members reactivated."
>
  <article class="mini-case-study">
    <!-- Header -->
    <header class="mini-header">
      <a href="/#work" class="back-link">&larr; back to work</a>
      <p class="project-label">Credit Karma Money</p>
      <h1>Cross-Product Landing Pages</h1>
      <p class="project-tagline">Cross-product landing page optimization — 2.6M churned members reactivated.</p>
    </header>

    <!-- Two Column Layout -->
    <div class="mini-layout">
      <!-- Left: Sticky Image -->
      <div class="mini-image-column">
        <div class="mini-image-wrapper">
          <Image src={columnImage} alt="RAD splash page screen" width={400} densities={[1, 2]} />
        </div>
      </div>

      <!-- Right: Content -->
      <div class="mini-content-column">
        <section class="mini-section">
          <h2>Context</h2>
          <p>I was the lead content designer on the TT2CKM (TurboTax to Credit Karma Money) track, focused on convincing TurboTax filers to deposit their refund into a Credit Karma Money account. Both products are under the Intuit umbrella, but getting people to opt in was an uphill battle—it required filers to open a CKM account mid-filing.</p>
          <p>At the "finish and file" stage, we'd surface a splash page for one of our CKM refund offerings: Refund Advance (a no-fee, no-interest loan of up to $4,000) or CKM Savings with benefits like Credit Builder and early payday. These products came with a lot of legally-sensitive language and often inspired distrust given their position as a mid-file upsell.</p>
          <p>The post-file pages then funneled completed filers into Credit Karma to open additional accounts or access their digital debit card for instant spending.</p>
        </section>

        <section class="mini-section">
          <h2>The fix</h2>
          <p>Anchor on benefit-focused copy that spoke to customer needs. Prioritize transparency and brevity, which was challenging given the disclosure requirements and the inherent skepticism around these offers.</p>
        <p>For postfile, the same fixes apply, plus optimizing CTAs and progress bar visuals to make the jump from TT to CK feel like the next logical, low-lift step.</p>
</section>

        <section class="mini-section">
          <h2>My input</h2>
          <ul>
            <li>A/B tested content variations to find what resonated most with TurboTax audiences</li>
            <li>Worked with marketing to build a cohesive narrative with top-of-funnel product messaging</li>
            <li>Collaborated with legal to strip away as much legalese as possible so the offer could shine through</li>
          </ul>
        </section>

        <section class="mini-section">
          <h2>Impact</h2>
          <p><strong>2.6M churned and 90-day inactive CK members reactivated</strong> with our optimized splash and post-file pages.</p>
        </section>
      </div>
    </div>

    <!-- Full Width Image -->
    <div class="full-width-image">
      <Image src={fullWidthImage} alt="Splash and post-file pages overview" width={1200} densities={[1, 2]} />
    </div>
  </article>
</BaseLayout>

<style>
  .mini-case-study {
    max-width: 100%;
  }

  /* Header */
  .mini-header {
    padding: var(--space-12) 0 var(--space-8);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-12);
  }

  .back-link {
    font-size: 0.875rem;
    color: var(--color-muted);
    display: inline-block;
    margin-bottom: var(--space-6);
  }

  .back-link:hover {
    color: var(--color-text);
    opacity: 1;
  }

  .project-label {
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    margin-bottom: var(--space-2);
  }

  .mini-header h1 {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    margin-bottom: var(--space-3);
    line-height: 1.2;
  }

  .project-tagline {
    font-size: 1rem;
    color: var(--color-muted);
    max-width: 500px;
    line-height: 1.6;
  }

  /* Two Column Layout */
  .mini-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  /* Left Column - Sticky Image */
  .mini-image-column {
    position: sticky;
    top: var(--space-8);
  }

  .mini-image-wrapper {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    max-width: 360px;
  }

  .mini-image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
  }

  .image-placeholder {
    aspect-ratio: 3 / 4;
    background: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    font-size: 0.875rem;
  }

  /* Right Column - Content */
  .mini-content-column {
    padding-bottom: var(--space-16);
  }

  .mini-section {
    margin-bottom: var(--space-12);
  }

  .mini-section:last-child {
    margin-bottom: 0;
  }

  .mini-section h2 {
    font-size: 1.25rem;
    font-family: var(--font-heading);
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: var(--space-6);
  }

  .mini-section p {
    line-height: 1.7;
    margin-bottom: var(--space-4);
  }

  .mini-section p:last-child {
    margin-bottom: 0;
  }

  .mini-section ul {
    margin: var(--space-4) 0 var(--space-6);
    padding-left: var(--space-8);
    line-height: 1.7;
  }

  .mini-section ul li {
    margin-bottom: var(--space-3);
  }

  /* Full Width Image */
  .full-width-image {
    margin-top: var(--space-16);
  }

  .full-width-image img {
    width: 100%;
    border-radius: 8px;
    border: 1px solid var(--color-border);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .mini-layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .mini-image-column {
      position: relative;
      top: 0;
    }

    .image-placeholder {
      aspect-ratio: 16 / 10;
    }
  }
</style>
